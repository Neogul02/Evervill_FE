{
  "rewrites": [
    {
      "source": "/api/ws/:path*",
      "destination": "http://168.107.54.139:8080/api/ws/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "http://168.107.54.139:8080/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "http://168.107.54.139:8080/auth/:path*"
    },
    {
      "source": "/oauth2/callback",
      "destination": "/index.html"
    },
    {
      "source": "/oauth2/:path*",
      "destination": "http://168.107.54.139:8080/oauth2/:path*"
    },
    {
      "source": "/login/oauth2/:path*",
      "destination": "http://168.107.54.139:8080/login/oauth2/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
